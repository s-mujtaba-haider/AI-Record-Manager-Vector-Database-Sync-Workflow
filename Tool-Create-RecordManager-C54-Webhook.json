    {
      "parameters": {
        "jsCode": "// Get Supabase records from current input\nconst Records = $items('Get Records').map(item => item.json).filter(record => record && record.post_id !== undefined);\n\n// Get API IDs from another node\nconst apiIds = $items('Extract API IDs')[0].json.ids || [];\n\n// Filter records that are in Supabase but not in API\nconst deleted = Records.filter(record => !apiIds.includes(record.post_id));\n\n// Prepare final result as a single object\nreturn [\n  {\n    json: {\n      ids: deleted.map(r => r.post_id)\n    }\n  }\n];\n\n"
      },
