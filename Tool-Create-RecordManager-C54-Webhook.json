      "parameters": {
        "jsCode": "return items.map((item, index) => {\n  // 1. Get data from Loop Over Items\n  const loopItem = $item(index).$node[\"Remove-Latest-Episode(null)\"].json;\n\n  // 2. Get corresponding episode data\n  const extractItem = $item(index).$node[\"Extract-Episode\"].json;\n\n  // 3. Merge and conditionally add episode_number only if not null\n  const updatedJson = { ...loopItem };\n\n  if (extractItem.episode_number !== null && extractItem.episode_number !== undefined) {\n    updatedJson.episode_number = extractItem.episode_number;\n  }\n\n  return {\n    json: {\n      content_to_hash: JSON.stringify(updatedJson)\n    }\n  };\n});\n\n"
      },
