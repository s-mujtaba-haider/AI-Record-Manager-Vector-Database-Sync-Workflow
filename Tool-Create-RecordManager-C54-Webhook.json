        "jsCode": "\n\nreturn items.map(item => {\n  let data = { ...item.json };\n\n  // Remove latest_episode if it's null\n  if (data.hasOwnProperty(\"latest_episode\") && data.latest_episode === null) {\n    delete data.latest_episode;\n  }\n\n  return { json: data };\n});\n"
