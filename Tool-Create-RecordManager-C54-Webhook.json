    {
      "parameters": {
        "jsCode": "const item = $node['Loop Over Items'].json;\n\n// Extract episode number from \"link\"\nlet episodeNumber = null;\nif (item.link) {\n  const match = item.link.match(/episode-(\\d+)/i);\n  if (match) {\n    episodeNumber = parseInt(match[1], 10);\n  }\n}\n\n\nreturn [\n  {\n    episode_no: episodeNumber\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
